<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Eventex - Full Event Template</title>
    
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" type="text/css" href="https://cdn.jsdelivr.net/npm/slick-carousel@1.8.1/slick/slick.css"/>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css"/>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    
    <style>
        :root {
            --purple-main: #9c27b0;
            --purple-dark: #7b1fa2;
            --accent-red: #ff4a57;
            --dark-blue: #0b0d39;
            --light-bg: #fdfdfd;
        }

        body { font-family: 'Arial', sans-serif; overflow-x: hidden; color: #444; }

        /* --- Floating Background Icons --- */
        .bg-icon { position: absolute; z-index: 1; opacity: 0.15; animation: floatingIcon 6s ease-in-out infinite; }
        .dots-grid { top: 10%; left: 5%; display: grid; grid-template-columns: repeat(8, 8px); grid-gap: 12px; }
        .dots-grid span { width: 8px; height: 8px; background: #999; border-radius: 50%; }
        .shape-circle { top: 20%; left: 40%; width: 50px; height: 50px; border: 6px solid var(--purple-main); border-radius: 50%; }
        .shape-triangle { bottom: 15%; left: 10%; width: 0; height: 0; border-left: 20px solid transparent; border-right: 20px solid transparent; border-bottom: 35px solid var(--accent-red); }
        
        @keyframes floatingIcon {
            0%, 100% { transform: translateY(0) rotate(0deg); }
            50% { transform: translateY(-20px) rotate(10deg); }
        }

        /* --- Header & Navbar --- */
        .top-bar { background: var(--purple-main); color: white; padding: 10px 0; font-size: 13px; }
        .navbar-brand { font-weight: 800; color: var(--dark-blue) !important; font-size: 28px; }
        .nav-link { font-weight: 600; color: var(--dark-blue); margin: 0 10px; }
        .btn-contact { background: var(--purple-main); color: white; padding: 10px 25px; border-radius: 5px; text-decoration: none; }

        /* --- Hero Section --- */
        .hero-section { position: relative; min-height: 90vh; background: var(--light-bg); display: flex; align-items: center; }
        .hero-content h1 { font-size: clamp(40px, 6vw, 75px); font-weight: 900; color: var(--dark-blue); line-height: 1.1; }
        .hero-content h1 span { color: var(--accent-red); }
        .hero-content p { font-size: 18px; margin: 25px 0; max-width: 500px; }
        
        .right-image-wrap { 
            position: absolute; top: 0; right: 0; width: 45%; height: 100%; 
            background: url('https://images.unsplash.com/photo-1492684223066-81342ee5ff30?auto=format&fit=crop&w=1000&q=80') center/cover;
            clip-path: polygon(25% 0%, 100% 0%, 100% 100%, 0% 100%, 15% 50%);
            display: flex; align-items: center; justify-content: center;
        }
        
        /* Play Button */
        .play-btn {
            width: 80px; height: 80px; background: white; border-radius: 50%;
            display: flex; align-items: center; justify-content: center;
            box-shadow: 0 10px 20px rgba(0,0,0,0.2); position: relative;
        }
        .play-btn::after {
            content: ''; position: absolute; width: 100%; height: 100%;
            border: 2px solid white; border-radius: 50%; animation: pulse 2s infinite;
        }
        @keyframes pulse { 0% {transform: scale(1); opacity: 1;} 100% {transform: scale(1.8); opacity: 0;} }

        /* --- Stats Bar --- */
        .stats-bar { background: var(--purple-main); color: white; padding: 40px 0; margin-top: -50px; position: relative; z-index: 10; border-radius: 10px; }
        .stat-item h2 { font-weight: 800; font-size: 40px; margin: 0; }

        /* --- Sections Common --- */
        .section-padding { padding: 100px 0; position: relative; }
        .section-title { text-align: center; margin-bottom: 60px; }
        .section-title h2 { font-size: 45px; font-weight: 800; color: var(--dark-blue); }
        .section-title h2 span { color: var(--accent-red); }

        /* --- Cards & Components --- */
        .feature-card { padding: 40px; border: 1px solid #eee; transition: 0.3s; background: white; height: 100%; }
        .feature-card:hover { transform: translateY(-10px); box-shadow: 0 15px 30px rgba(0,0,0,0.1); }
        .feature-card i { font-size: 40px; color: var(--accent-red); margin-bottom: 20px; display: block; }

        .speaker-card { text-align: center; margin-bottom: 30px; }
        .speaker-img { width: 100%; border-radius: 10px; margin-bottom: 15px; }
        
        .pricing-card { padding: 50px 30px; border-radius: 15px; text-align: center; border: 1px solid #eee; transition: 0.3s; }
        .pricing-card.featured { background: var(--accent-red); color: white; border: none; transform: scale(1.05); }
        .pricing-card h3 { font-size: 50px; font-weight: 800; }

        /* --- Footer --- */
        footer { background: var(--dark-blue); color: white; padding: 80px 0 20px; }
        .footer-logo { font-size: 30px; font-weight: 800; margin-bottom: 20px; display: block; color: white; text-decoration: none; }

        @media (max-width: 991px) {
            .right-image-wrap { position: relative; width: 100%; height: 400px; clip-path: none; margin-top: 50px; }
            .hero-section { text-align: center; padding-top: 50px; }
            .hero-content p { margin: 20px auto; }
        }
    </style>
</head>
<body>

    <div class="top-bar d-none d-lg-block">
        <div class="container">
            <div class="row">
